# Local mode (default)
# STORAGE_PROVIDER=local

# S3 mode
# STORAGE_PROVIDER=s3
# S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

# Optional for S3-compatible providers (Cloudflare R2, MinIO, etc.)
# S3_ENDPOINT=https://your-endpoint
# S3_FORCE_PATH_STYLE=true

# Optional explicit credentials
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Owner dashboard authentication
# OWNER_USERNAME=eli
# OWNER_PASSWORD=password
AUTH_SESSION_TTL_HOURS=24
# Optional: force generated share links to use this base URL
# Example: PUBLIC_BASE_URL=https://photos.yourdomain.com
PUBLIC_BASE_URL=
